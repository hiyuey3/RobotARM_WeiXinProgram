/* 你说机械做的心会梦见电子蝴蝶吗？
 Created by Yue

*/
page {
  background-color: #f5f5f5;
}

.container {
  width: 100%;
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: block;
  align-items: stretch;
  justify-content: flex-start;
}

.btn.disabled {
  background-color: #d9d9d9;
  color: #999;
}

.btn-small::after {
  border: none;
}

.video-section {
  width: 100%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.video-player {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  background-color: #000;
  display: block;
}

.video-placeholder {
  display: block;
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.control-section {
  width: 100%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.control-section-content.disabled-section {
  opacity: 0.5;
  pointer-events: none;
}

.status-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.status-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  text-align: center;
  word-break: break-all;
  padding: 12rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  max-width: 100%;
}

.status-btn {
  font-size: 28rpx;
  padding: 12rpx 40rpx;
  border-radius: 50rpx;
  border: none;
  font-weight: 600;
  line-height: 1.5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-connect {
  background-color: #1890ff;
  color: #fff;
}

.status-connect[disabled="true"] {
  background-color: #d9d9d9;
  color: #999;
}

.status-disconnect {
  background-color: #ff4d4f;
  color: #fff;
}

.status-btn::after {
  border: none;
}

.control-group {
  margin-bottom: 36rpx;
}

.control-group:last-child {
  margin-bottom: 20rpx;
}

.device-input {
  width: 100%;
  height: 70rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fff;
}

.device-input[disabled="true"] {
  background-color: #f5f5f5;
  color: #ccc;
}



.label {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
  line-height: 1.4;
}

.slider {
  width: 90%;
  display: block;
}

.button-group {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 40rpx;
}

.report-box {
  margin-top: 24rpx;
}

.report-list {
  width: 100%;
  background-color: #fafafa;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 12rpx;
  box-sizing: border-box;
}

.report-item {
  font-size: 24rpx;
  color: #333;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.report-item:last-child {
  border-bottom: none;
}

.btn {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-primary {
  background-color: #1890ff;
  color: #fff;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background-color: #faad14;
  color: #fff;
}

.btn-secondary::after {
  border: none;
}

.btn-danger {
  background-color: #ff4d4f;
  color: #fff;
}

.btn-danger::after {
  border: none;
}
